{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
%}

<section class="loubaan-finder" id="Duftfinder-{{ section.id }}">
  <div class="finder-ambient finder-ambient--one"></div>
  <div class="finder-ambient finder-ambient--two"></div>

  <div class="finder-shell">
    <div class="finder-top">
      <span class="finder-kicker">{{ section.settings.kicker }}</span>
      <h2>{{ heading }}</h2>
      <p>{{ subheading }}</p>
    </div>

    <div class="finder-progress-wrap" aria-hidden="true">
      <div class="finder-progress-bar"><span data-progress></span></div>
      <div class="finder-progress-label"><span data-progress-text>Frage 1 von 4</span></div>
    </div>

    <div class="finder-state" data-state></div>

    <div class="finder-question" data-question></div>

    <div class="finder-actions">
      <button type="button" class="finder-btn finder-btn--ghost" data-back disabled>Zurück</button>
      <button type="button" class="finder-btn" data-reset hidden>Neu starten</button>
    </div>
  </div>

  <script type="application/json" data-products>
    [
      {% for block in section.blocks %}
        {
          "title": {{ block.settings.title | default: block.settings.product.title | json }},
          "subtitle": {{ block.settings.subtitle | json }},
          "description": {{ block.settings.description | json }},
          "url": {{ block.settings.link | default: block.settings.product.url | json }},
          "image": {{ block.settings.product.featured_image | image_url: width: 400 | json }},
          "price": {{ block.settings.product.price | money_without_trailing_zeros | json }},
          "mood": {{ block.settings.mood_tags | downcase | split: ',' | json }},
          "atmosphere": {{ block.settings.atmosphere_tags | downcase | split: ',' | json }},
          "character": {{ block.settings.character_tags | downcase | split: ',' | json }},
          "intensity": {{ block.settings.intensity_tags | downcase | split: ',' | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  </script>
</section>

<style>
  #Duftfinder-{{ section.id }} {
    --finder-bg: #f7f2ea;
    --finder-text: #2c2b29;
    --finder-muted: #6c645d;
    --finder-accent: #7c6555;
    --finder-accent-soft: rgba(124, 101, 85, 0.18);
    position: relative;
    padding: clamp(2rem, 4vw, 4rem) clamp(1rem, 3vw, 2rem);
    border-radius: 24px;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(circle at 8% 12%, #ffffff 0%, rgba(255, 255, 255, 0) 40%),
      linear-gradient(130deg, #faf5ee, #f2ebe1);
    min-height: 600px;
  }

  #Duftfinder-{{ section.id }} .finder-ambient {
    position: absolute;
    border-radius: 999px;
    filter: blur(55px);
    opacity: 0.55;
    z-index: -1;
    animation: finderFloat 18s ease-in-out infinite alternate;
  }

  #Duftfinder-{{ section.id }} .finder-ambient--one {
    width: 320px;
    height: 320px;
    right: -90px;
    top: -100px;
    background: #dfd3c4;
  }

  #Duftfinder-{{ section.id }} .finder-ambient--two {
    width: 280px;
    height: 280px;
    left: -120px;
    bottom: -120px;
    background: #f8e8cf;
    animation-duration: 24s;
  }

  #Duftfinder-{{ section.id }} .finder-shell {
    max-width: 900px;
    margin: 0 auto;
    backdrop-filter: blur(8px);
  }

  #Duftfinder-{{ section.id }} .finder-top {
    text-align: center;
    margin-bottom: 2rem;
  }

  #Duftfinder-{{ section.id }} .finder-kicker {
    display: inline-flex;
    margin-bottom: 0.7rem;
    padding: 0.4rem 0.95rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--finder-accent);
    border: 1px solid var(--finder-accent-soft);
    background: rgba(255, 255, 255, 0.7);
  }

  #Duftfinder-{{ section.id }} h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.2;
    font-family: "Times New Roman", serif;
    color: var(--finder-text);
  }

  #Duftfinder-{{ section.id }} .finder-top p {
    margin: 0.65rem auto 0;
    color: var(--finder-muted);
    max-width: 52ch;
  }

  #Duftfinder-{{ section.id }} .finder-progress-wrap {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  #Duftfinder-{{ section.id }} .finder-progress-bar {
    width: 100%;
    height: 8px;
    border-radius: 999px;
    background: rgba(124, 101, 85, 0.12);
    overflow: hidden;
  }

  #Duftfinder-{{ section.id }} .finder-progress-bar span {
    display: block;
    width: 25%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #7c6555, #9c8573);
    transition: width 0.35s ease;
  }

  #Duftfinder-{{ section.id }} .finder-progress-label {
    display: flex;
    justify-content: flex-end;
    font-size: 0.82rem;
    color: var(--finder-muted);
    font-weight: 500;
  }

  #Duftfinder-{{ section.id }} .finder-state {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
    min-height: 2rem;
    justify-content: center;
  }

  #Duftfinder-{{ section.id }} .finder-pill {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(124, 101, 85, 0.16);
    color: var(--finder-accent);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
  }

  #Duftfinder-{{ section.id }} .finder-question-title {
    margin: 0 0 0.5rem;
    font-family: "Times New Roman", serif;
    font-size: clamp(1.35rem, 3vw, 1.9rem);
    color: var(--finder-text);
    text-align: center;
  }

  #Duftfinder-{{ section.id }} .finder-question-subtitle {
    margin: 0 0 1.5rem;
    color: var(--finder-muted);
    text-align: center;
  }

  #Duftfinder-{{ section.id }} .finder-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  #Duftfinder-{{ section.id }} .finder-option {
    border: 1px solid rgba(124, 101, 85, 0.17);
    border-radius: 16px;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.8);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: center;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  #Duftfinder-{{ section.id }} .finder-option:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 24px rgba(42, 35, 29, 0.1);
    border-color: rgba(124, 101, 85, 0.35);
    background: rgba(255, 255, 255, 0.95);
  }

  #Duftfinder-{{ section.id }} .finder-option .emoji {
    font-size: 2rem;
    margin-bottom: 0.3rem;
  }

  #Duftfinder-{{ section.id }} .finder-option strong {
    font-size: 1rem;
    color: var(--finder-text);
  }

  #Duftfinder-{{ section.id }} .finder-option span {
    color: var(--finder-muted);
    font-size: 0.85rem;
  }

  #Duftfinder-{{ section.id }} .finder-actions {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  #Duftfinder-{{ section.id }} .finder-btn {
    border: 1px solid #2a2a2a;
    border-radius: 999px;
    background: #2a2a2a;
    color: #fff;
    padding: 0.7rem 1.3rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  #Duftfinder-{{ section.id }} .finder-btn:hover {
    background: #fff;
    color: #2a2a2a;
  }

  #Duftfinder-{{ section.id }} .finder-btn--ghost {
    color: #2a2a2a;
    background: transparent;
  }

  #Duftfinder-{{ section.id }} .finder-btn--ghost:hover {
    background: rgba(0,0,0,0.05);
  }

  #Duftfinder-{{ section.id }} .finder-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Results */
  #Duftfinder-{{ section.id }} .finder-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
    margin-top: 1rem;
  }

  #Duftfinder-{{ section.id }} .finder-result-card {
    border-radius: 20px;
    border: 1px solid rgba(124, 101, 85, 0.2);
    background: rgba(255, 255, 255, 0.9);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: all 0.3s ease;
  }

  #Duftfinder-{{ section.id }} .finder-result-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgba(124, 101, 85, 0.15);
  }

  #Duftfinder-{{ section.id }} .finder-result-card[data-top='true'] {
    border: 2px solid var(--finder-accent);
    box-shadow: 0 14px 28px rgba(124, 101, 85, 0.15);
  }

  #Duftfinder-{{ section.id }} .finder-result-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 0.5rem;
  }

  #Duftfinder-{{ section.id }} .finder-score {
    font-size: 0.73rem;
    font-weight: 700;
    color: #0f766e;
    background: #ecfdf5;
    border: 1px solid #d1fae5;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    align-self: flex-start;
  }

  #Duftfinder-{{ section.id }} .finder-result-card h3 {
    margin: 0;
    font-family: "Times New Roman", serif;
    font-size: 1.3rem;
    color: var(--finder-text);
  }

  #Duftfinder-{{ section.id }} .finder-meta {
    font-size: 0.9rem;
    color: var(--finder-muted);
    margin: 0;
    line-height: 1.5;
  }

  #Duftfinder-{{ section.id }} .finder-price {
    font-size: 1rem;
    font-weight: 600;
    color: var(--finder-text);
  }

  #Duftfinder-{{ section.id }} .finder-link {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    border-radius: 999px;
    text-decoration: none;
    margin-top: auto;
    padding: 0.7rem 1rem;
    background: #2a2a2a;
    color: #fff;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  #Duftfinder-{{ section.id }} .finder-link:hover {
    background: var(--finder-accent);
  }

  @media (max-width: 600px) {
    #Duftfinder-{{ section.id }} .finder-grid {
      grid-template-columns: 1fr;
    }
    #Duftfinder-{{ section.id }} .finder-option {
      flex-direction: row;
      text-align: left;
      gap: 1rem;
    }
    #Duftfinder-{{ section.id }} .finder-option .emoji {
      font-size: 1.8rem;
      margin: 0;
    }
  }

  @keyframes finderFloat {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(25px, -15px, 0) scale(1.08); }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('Duftfinder-{{ section.id }}');
    if (!root) return;

    const questionContainer = root.querySelector('[data-question]');
    const stateContainer = root.querySelector('[data-state]');
    const backBtn = root.querySelector('[data-back]');
    const resetBtn = root.querySelector('[data-reset]');
    const progress = root.querySelector('[data-progress]');
    const progressText = root.querySelector('[data-progress-text]');
    
    let productData = [];
    try {
      productData = JSON.parse(root.querySelector('[data-products]').textContent.trim() || '[]');
    } catch (e) {
      console.warn('Duftfinder: Could not parse products', e);
    }

    const fallbackProducts = [
      { title: 'Weihrauch Premium', subtitle: 'Tiefe & Mystik', description: 'Traditioneller Weihrauch für meditative Momente.', price: '24,90 €', url: '/collections/weihrauch', mood: ['ruhig', 'sinnlich'], atmosphere: ['ritual', 'zuhause'], character: ['harzig'], intensity: ['tief', 'ausgewogen'] },
      { title: 'Oud Deluxe', subtitle: 'Luxuriös & Warm', description: 'Edler Oud für besondere Anlässe.', price: '39,90 €', url: '/collections/oud', mood: ['warm', 'sinnlich'], atmosphere: ['ritual', 'spa'], character: ['holzig', 'harzig'], intensity: ['tief'] },
      { title: 'Bakhoor Rose', subtitle: 'Blumig & Elegant', description: 'Rosenduft mit orientalischer Note.', price: '29,90 €', url: '/collections/bakhoor', mood: ['warm', 'ruhig'], atmosphere: ['zuhause', 'spa'], character: ['blumig'], intensity: ['ausgewogen', 'sanft'] }
    ];

    const products = productData.length ? productData : fallbackProducts;

    const steps = [
      {
        key: 'mood',
        title: 'Wie möchtest du dich fühlen?',
        subtitle: 'Wähle das Gefühl, das dich begleiten soll.',
        options: [
          { value: 'ruhig', emoji: '🍃', label: 'Ruhig & entspannt', desc: 'Entschleunigung' },
          { value: 'warm', emoji: '🌅', label: 'Warm & geborgen', desc: 'Geborgenheit' },
          { value: 'klar', emoji: '🏔️', label: 'Klar & fokussiert', desc: 'Konzentration' },
          { value: 'sinnlich', emoji: '🌙', label: 'Sinnlich & tief', desc: 'Intensität' }
        ]
      },
      {
        key: 'atmosphere',
        title: 'Welche Atmosphäre suchst du?',
        subtitle: 'Wo soll dich der Duft hinbringen?',
        options: [
          { value: 'natur', emoji: '🌲', label: 'Natur & Wald', desc: 'Erdung & Frische' },
          { value: 'spa', emoji: '🧖‍♀️', label: 'Luxus Spa', desc: 'Wellness' },
          { value: 'zuhause', emoji: '🏠', label: 'Gemütliches Zuhause', desc: 'Kamin & Kerzen' },
          { value: 'ritual', emoji: '🕌', label: 'Tempel & Ritual', desc: 'Mystik & Tiefe' }
        ]
      },
      {
        key: 'character',
        title: 'Welchen Charakter bevorzugst du?',
        subtitle: 'Was spricht dich am meisten an?',
        options: [
          { value: 'blumig', emoji: '🌸', label: 'Blumig & weich', desc: 'Zart & elegant' },
          { value: 'holzig', emoji: '🪵', label: 'Holzig & klar', desc: 'Stark & natürlich' },
          { value: 'suess', emoji: '🍯', label: 'Süß & gourmand', desc: 'Vanille & Honig' },
          { value: 'harzig', emoji: '✨', label: 'Harzig & balsamisch', desc: 'Weihrauch & Amber' }
        ]
      },
      {
        key: 'intensity',
        title: 'Wie intensiv darf es sein?',
        subtitle: 'Deine Duft-Vorliebe.',
        options: [
          { value: 'sanft', emoji: '☁️', label: 'Sanft & dezent', desc: 'Leise im Hintergrund' },
          { value: 'ausgewogen', emoji: '⚖️', label: 'Ausgewogen', desc: 'Präsent, nicht laut' },
          { value: 'tief', emoji: '🔥', label: 'Tief & intensiv', desc: 'Raumfüllend' },
          { value: 'frisch', emoji: '🌿', label: 'Klar & frisch', desc: 'Belebend' }
        ]
      }
    ];

    const answers = {};
    let currentStep = 0;

    const normalize = (str) => (str || '').toString().toLowerCase().trim();

    const setProgress = () => {
      const ratio = ((currentStep + 1) / steps.length) * 100;
      progress.style.width = `${Math.min(ratio, 100)}%`;
      progressText.textContent = `Frage ${currentStep + 1} von ${steps.length}`;
      backBtn.disabled = currentStep === 0;
    };

    const renderState = () => {
      stateContainer.innerHTML = Object.entries(answers)
        .map(([, value]) => `<span class="finder-pill">${value}</span>`)
        .join('');
    };

    const renderQuestion = () => {
      const step = steps[currentStep];
      questionContainer.innerHTML = `
        <h3 class="finder-question-title">${step.title}</h3>
        <p class="finder-question-subtitle">${step.subtitle}</p>
        <div class="finder-grid">
          ${step.options.map((opt) => `
            <button class="finder-option" data-value="${opt.value}" type="button">
              <span class="emoji">${opt.emoji}</span>
              <div>
                <strong>${opt.label}</strong>
                <span>${opt.desc}</span>
              </div>
            </button>
          `).join('')}
        </div>
      `;

      questionContainer.querySelectorAll('[data-value]').forEach((btn) => {
        btn.addEventListener('click', () => {
          answers[step.key] = btn.dataset.value;
          renderState();

          if (currentStep < steps.length - 1) {
            currentStep += 1;
            renderQuestion();
            setProgress();
            return;
          }

          renderResults();
        });
      });

      setProgress();
    };

    const rankProducts = () => {
      const scored = products.map((product) => {
        let score = 0;

        steps.forEach((step) => {
          const answer = normalize(answers[step.key]);
          const tags = Array.isArray(product[step.key]) ? product[step.key].map(normalize) : [];
          if (tags.includes(answer)) {
            score += 25;
          }
        });

        return { ...product, score };
      });

      return scored.sort((a, b) => b.score - a.score).slice(0, 3);
    };

    const renderResults = () => {
      const matches = rankProducts();
      
      questionContainer.innerHTML = `
        <h3 class="finder-question-title">Deine Duft-Empfehlungen</h3>
        <p class="finder-question-subtitle">Basierend auf deinen Antworten haben wir diese Favoriten gefunden.</p>
        <div class="finder-results">
          ${matches.map((item, index) => `
            <article class="finder-result-card" data-top="${index === 0}">
              ${item.image ? `<img class="finder-result-img" src="${item.image}" alt="${item.title}" loading="lazy">` : ''}
              <span class="finder-score">${item.score}% Match</span>
              <h3>${item.title || 'LOUBAAN Duft'}</h3>
              ${item.subtitle ? `<p class="finder-meta">${item.subtitle}</p>` : ''}
              ${item.price ? `<p class="finder-price">${item.price}</p>` : ''}
              <p class="finder-meta">${item.description || 'Ein handverlesener Duft für besondere Momente.'}</p>
              <a class="finder-link" href="${item.url || '/collections/all'}">Zum Produkt</a>
            </article>
          `).join('')}
        </div>
      `;

      progress.style.width = '100%';
      progressText.textContent = 'Fertig';
      backBtn.hidden = true;
      resetBtn.hidden = false;
    };

    const reset = () => {
      Object.keys(answers).forEach((k) => delete answers[k]);
      currentStep = 0;
      backBtn.hidden = false;
      backBtn.disabled = true;
      resetBtn.hidden = true;
      renderState();
      renderQuestion();
    };

    backBtn.addEventListener('click', () => {
      if (currentStep === 0) return;
      delete answers[steps[currentStep].key];
      currentStep -= 1;
      renderState();
      renderQuestion();
    });

    resetBtn.addEventListener('click', reset);

    // Init
    renderQuestion();
  })();
</script>

{% schema %}
{
  "name": "Duftfinder",
  "tag": "section",
  "class": "section-duftfinder",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker Text",
      "default": "✨ Dein KI Duftberater"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Finde deinen perfekten Duft"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile",
      "default": "Beantworte 4 kurze Fragen und entdecke Düfte, die zu dir passen."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produkt",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel (überschreibt Produktname)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Untertitel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Kurzbeschreibung"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (überschreibt Produkt-URL)"
        },
        {
          "type": "text",
          "id": "mood_tags",
          "label": "Mood Tags",
          "info": "Kommagetrennt: ruhig, warm, klar, sinnlich"
        },
        {
          "type": "text",
          "id": "atmosphere_tags",
          "label": "Atmosphäre Tags",
          "info": "Kommagetrennt: natur, spa, zuhause, ritual"
        },
        {
          "type": "text",
          "id": "character_tags",
          "label": "Charakter Tags",
          "info": "Kommagetrennt: blumig, holzig, suess, harzig"
        },
        {
          "type": "text",
          "id": "intensity_tags",
          "label": "Intensität Tags",
          "info": "Kommagetrennt: sanft, ausgewogen, tief, frisch"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duftfinder",
      "blocks": []
    }
  ]
}
{% endschema %}
