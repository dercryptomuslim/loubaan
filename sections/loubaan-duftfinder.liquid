{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
%}

<section class="duftfinder" id="Duftfinder-{{ section.id }}">
  <div class="duftfinder__inner">
    <header class="duftfinder__header">
      <span class="duftfinder__kicker">{{ section.settings.kicker }}</span>
      <h2 class="duftfinder__title">{{ heading }}</h2>
      <p class="duftfinder__subtitle">{{ subheading }}</p>
    </header>

    <div class="duftfinder__progress" aria-hidden="true">
      <div class="duftfinder__progress-track">
        <div class="duftfinder__progress-fill" data-progress></div>
      </div>
      <span class="duftfinder__progress-text" data-progress-text>1 / 4</span>
    </div>

    <div class="duftfinder__selections" data-state></div>

    <div class="duftfinder__content" data-question></div>

    <nav class="duftfinder__nav">
      <button type="button" class="duftfinder__btn duftfinder__btn--back" data-back disabled>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Zurück
      </button>
      <button type="button" class="duftfinder__btn duftfinder__btn--reset" data-reset hidden>Neu starten</button>
    </nav>
  </div>

  <script type="application/json" data-products>
    [
      {% for block in section.blocks %}
        {
          "title": {{ block.settings.title | default: block.settings.product.title | json }},
          "subtitle": {{ block.settings.subtitle | json }},
          "description": {{ block.settings.description | json }},
          "url": {{ block.settings.link | default: block.settings.product.url | json }},
          "image": {{ block.settings.product.featured_image | image_url: width: 400 | json }},
          "price": {{ block.settings.product.price | money_without_trailing_zeros | json }},
          "mood": {{ block.settings.mood_tags | downcase | split: ',' | json }},
          "atmosphere": {{ block.settings.atmosphere_tags | downcase | split: ',' | json }},
          "character": {{ block.settings.character_tags | downcase | split: ',' | json }},
          "intensity": {{ block.settings.intensity_tags | downcase | split: ',' | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  </script>
</section>

<style>
  /* ============================================
     LOUBAAN DUFTFINDER — Impeccable Design
     Editorial/Refined aesthetic for premium brand
     ============================================ */

  #Duftfinder-{{ section.id }} {
    /* OKLCH Color System — warm-tinted neutrals */
    --df-bg: oklch(97% 0.008 60);
    --df-surface: oklch(99% 0.004 60);
    --df-border: oklch(88% 0.015 60);
    --df-text: oklch(25% 0.02 60);
    --df-text-muted: oklch(45% 0.015 60);
    --df-accent: oklch(45% 0.12 45);
    --df-accent-light: oklch(92% 0.03 45);
    --df-success: oklch(45% 0.12 155);
    
    /* Typography */
    --df-font-display: "Cormorant Garamond", "Times New Roman", serif;
    --df-font-body: "DM Sans", system-ui, sans-serif;
    
    /* Motion — exponential easing, no bounce */
    --ease-out: cubic-bezier(0.25, 1, 0.5, 1);
    --ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
    
    background: var(--df-bg);
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem);
  }

  #Duftfinder-{{ section.id }} .duftfinder__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Header */
  #Duftfinder-{{ section.id }} .duftfinder__header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  #Duftfinder-{{ section.id }} .duftfinder__kicker {
    display: inline-block;
    font-family: var(--df-font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--df-accent);
    margin-bottom: 1rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__title {
    font-family: var(--df-font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--df-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  #Duftfinder-{{ section.id }} .duftfinder__subtitle {
    font-family: var(--df-font-body);
    font-size: 1.0625rem;
    color: var(--df-text-muted);
    margin: 0;
    max-width: 45ch;
    margin-inline: auto;
    line-height: 1.6;
  }

  /* Progress */
  #Duftfinder-{{ section.id }} .duftfinder__progress {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__progress-track {
    flex: 1;
    height: 3px;
    background: var(--df-border);
    border-radius: 2px;
    overflow: hidden;
  }

  #Duftfinder-{{ section.id }} .duftfinder__progress-fill {
    width: 25%;
    height: 100%;
    background: var(--df-accent);
    border-radius: 2px;
    transition: width 400ms var(--ease-out);
  }

  #Duftfinder-{{ section.id }} .duftfinder__progress-text {
    font-family: var(--df-font-body);
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
    color: var(--df-text-muted);
    min-width: 3ch;
  }

  /* Selections (pills showing chosen answers) */
  #Duftfinder-{{ section.id }} .duftfinder__selections {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    min-height: 1.75rem;
    margin-bottom: 1.5rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__pill {
    font-family: var(--df-font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--df-accent);
    background: var(--df-accent-light);
    padding: 0.375rem 0.75rem;
    border-radius: 2rem;
  }

  /* Question Content */
  #Duftfinder-{{ section.id }} .duftfinder__question-title {
    font-family: var(--df-font-display);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 400;
    color: var(--df-text);
    text-align: center;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  #Duftfinder-{{ section.id }} .duftfinder__question-subtitle {
    font-family: var(--df-font-body);
    font-size: 0.9375rem;
    color: var(--df-text-muted);
    text-align: center;
    margin: 0 0 2rem;
  }

  /* Options Grid — NO nested cards */
  #Duftfinder-{{ section.id }} .duftfinder__options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--df-border);
    border: 1px solid var(--df-border);
    border-radius: 12px;
    overflow: hidden;
  }

  #Duftfinder-{{ section.id }} .duftfinder__option {
    background: var(--df-surface);
    border: none;
    padding: 1.5rem 1.25rem;
    text-align: left;
    cursor: pointer;
    transition: background 200ms var(--ease-out);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__option:hover {
    background: var(--df-accent-light);
  }

  #Duftfinder-{{ section.id }} .duftfinder__option:focus-visible {
    outline: 2px solid var(--df-accent);
    outline-offset: -2px;
    z-index: 1;
  }

  #Duftfinder-{{ section.id }} .duftfinder__option-label {
    font-family: var(--df-font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--df-text);
  }

  #Duftfinder-{{ section.id }} .duftfinder__option-desc {
    font-family: var(--df-font-body);
    font-size: 0.8125rem;
    color: var(--df-text-muted);
  }

  /* Navigation */
  #Duftfinder-{{ section.id }} .duftfinder__nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__btn {
    font-family: var(--df-font-body);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.75rem 1.25rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 200ms var(--ease-out);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__btn--back {
    background: transparent;
    border: 1px solid var(--df-border);
    color: var(--df-text-muted);
  }

  #Duftfinder-{{ section.id }} .duftfinder__btn--back:hover:not(:disabled) {
    border-color: var(--df-text-muted);
    color: var(--df-text);
  }

  #Duftfinder-{{ section.id }} .duftfinder__btn--back:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  #Duftfinder-{{ section.id }} .duftfinder__btn--reset {
    background: var(--df-text);
    border: 1px solid var(--df-text);
    color: var(--df-surface);
  }

  #Duftfinder-{{ section.id }} .duftfinder__btn--reset:hover {
    background: var(--df-accent);
    border-color: var(--df-accent);
  }

  /* Results */
  #Duftfinder-{{ section.id }} .duftfinder__results {
    display: grid;
    gap: 1.5rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__result {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--df-surface);
    border: 1px solid var(--df-border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 200ms var(--ease-out), box-shadow 200ms var(--ease-out);
  }

  #Duftfinder-{{ section.id }} .duftfinder__result:hover {
    border-color: var(--df-accent);
  }

  #Duftfinder-{{ section.id }} .duftfinder__result[data-top="true"] {
    border-color: var(--df-accent);
    box-shadow: 0 4px 24px oklch(45% 0.12 45 / 0.1);
  }

  #Duftfinder-{{ section.id }} .duftfinder__result-image {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 8px;
    background: var(--df-bg);
  }

  #Duftfinder-{{ section.id }} .duftfinder__result-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  #Duftfinder-{{ section.id }} .duftfinder__result-match {
    font-family: var(--df-font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--df-success);
  }

  #Duftfinder-{{ section.id }} .duftfinder__result-title {
    font-family: var(--df-font-display);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--df-text);
    margin: 0;
  }

  #Duftfinder-{{ section.id }} .duftfinder__result-subtitle {
    font-family: var(--df-font-body);
    font-size: 0.875rem;
    color: var(--df-text-muted);
  }

  #Duftfinder-{{ section.id }} .duftfinder__result-price {
    font-family: var(--df-font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--df-text);
    margin-top: auto;
  }

  /* Responsive */
  @media (max-width: 600px) {
    #Duftfinder-{{ section.id }} .duftfinder__options {
      grid-template-columns: 1fr;
    }

    #Duftfinder-{{ section.id }} .duftfinder__result {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
      padding: 1rem;
    }

    #Duftfinder-{{ section.id }} .duftfinder__result-image {
      width: 80px;
      height: 80px;
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    #Duftfinder-{{ section.id }} .duftfinder__progress-fill,
    #Duftfinder-{{ section.id }} .duftfinder__option,
    #Duftfinder-{{ section.id }} .duftfinder__btn,
    #Duftfinder-{{ section.id }} .duftfinder__result {
      transition-duration: 0.01ms !important;
    }
  }

  /* Animation for content transitions */
  @keyframes df-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #Duftfinder-{{ section.id }} .duftfinder__content[data-animate] {
    animation: df-fade-in 400ms var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    #Duftfinder-{{ section.id }} .duftfinder__content[data-animate] {
      animation: none;
    }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('Duftfinder-{{ section.id }}');
    if (!root) return;

    const $ = (sel) => root.querySelector(sel);
    const questionEl = $('[data-question]');
    const stateEl = $('[data-state]');
    const backBtn = $('[data-back]');
    const resetBtn = $('[data-reset]');
    const progressBar = $('[data-progress]');
    const progressText = $('[data-progress-text]');

    let products = [];
    try {
      products = JSON.parse($('[data-products]').textContent.trim() || '[]');
    } catch (e) {}

    const fallback = [
      { title: 'Weihrauch Premium', subtitle: 'Traditionell & Meditativ', description: 'Hochwertiger Weihrauch für tiefe Momente.', price: '24,90 €', url: '/collections/weihrauch', mood: ['ruhig', 'sinnlich'], atmosphere: ['ritual', 'zuhause'], character: ['harzig'], intensity: ['tief', 'ausgewogen'] },
      { title: 'Oud Deluxe', subtitle: 'Luxuriös & Warm', description: 'Edler Oud für besondere Anlässe.', price: '39,90 €', url: '/collections/oud', mood: ['warm', 'sinnlich'], atmosphere: ['ritual', 'spa'], character: ['holzig', 'harzig'], intensity: ['tief'] },
      { title: 'Bakhoor Rose', subtitle: 'Blumig & Elegant', description: 'Rosenduft mit orientalischer Note.', price: '29,90 €', url: '/collections/bakhoor', mood: ['warm', 'ruhig'], atmosphere: ['zuhause', 'spa'], character: ['blumig'], intensity: ['ausgewogen', 'sanft'] }
    ];

    if (!products.length) products = fallback;

    const steps = [
      { key: 'mood', title: 'Wie möchtest du dich fühlen?', subtitle: 'Wähle das Gefühl, das dich begleiten soll.',
        options: [
          { value: 'ruhig', label: 'Ruhig & Entspannt', desc: 'Entschleunigung & Harmonie' },
          { value: 'warm', label: 'Warm & Geborgen', desc: 'Geborgenheit & Nähe' },
          { value: 'klar', label: 'Klar & Fokussiert', desc: 'Konzentration & Klarheit' },
          { value: 'sinnlich', label: 'Sinnlich & Tief', desc: 'Intensität & Tiefe' }
        ]
      },
      { key: 'atmosphere', title: 'Welche Atmosphäre suchst du?', subtitle: 'Wo soll dich der Duft hinbringen?',
        options: [
          { value: 'natur', label: 'Natur & Wald', desc: 'Erdung & Frische' },
          { value: 'spa', label: 'Luxus Spa', desc: 'Wellness & Pflege' },
          { value: 'zuhause', label: 'Gemütliches Zuhause', desc: 'Kamin & Kerzenlicht' },
          { value: 'ritual', label: 'Tempel & Ritual', desc: 'Mystik & Spiritualität' }
        ]
      },
      { key: 'character', title: 'Welchen Charakter bevorzugst du?', subtitle: 'Was spricht dich am meisten an?',
        options: [
          { value: 'blumig', label: 'Blumig & Weich', desc: 'Zart & elegant' },
          { value: 'holzig', label: 'Holzig & Klar', desc: 'Stark & natürlich' },
          { value: 'suess', label: 'Süß & Gourmand', desc: 'Vanille & Honig' },
          { value: 'harzig', label: 'Harzig & Balsamisch', desc: 'Weihrauch & Amber' }
        ]
      },
      { key: 'intensity', title: 'Wie intensiv darf es sein?', subtitle: 'Deine Duft-Präferenz.',
        options: [
          { value: 'sanft', label: 'Sanft & Dezent', desc: 'Leise im Hintergrund' },
          { value: 'ausgewogen', label: 'Ausgewogen', desc: 'Präsent, nicht laut' },
          { value: 'tief', label: 'Tief & Intensiv', desc: 'Raumfüllend & stark' },
          { value: 'frisch', label: 'Klar & Frisch', desc: 'Belebend & leicht' }
        ]
      }
    ];

    const answers = {};
    let step = 0;

    const norm = (s) => (s || '').toString().toLowerCase().trim();

    const updateProgress = () => {
      const pct = ((step + 1) / steps.length) * 100;
      progressBar.style.width = `${pct}%`;
      progressText.textContent = `${step + 1} / ${steps.length}`;
      backBtn.disabled = step === 0;
    };

    const renderState = () => {
      stateEl.innerHTML = Object.values(answers)
        .map((v) => `<span class="duftfinder__pill">${v}</span>`)
        .join('');
    };

    const animate = () => {
      questionEl.removeAttribute('data-animate');
      void questionEl.offsetWidth; // reflow
      questionEl.setAttribute('data-animate', '');
    };

    const renderQuestion = () => {
      const s = steps[step];
      questionEl.innerHTML = `
        <h3 class="duftfinder__question-title">${s.title}</h3>
        <p class="duftfinder__question-subtitle">${s.subtitle}</p>
        <div class="duftfinder__options">
          ${s.options.map((o) => `
            <button type="button" class="duftfinder__option" data-value="${o.value}">
              <span class="duftfinder__option-label">${o.label}</span>
              <span class="duftfinder__option-desc">${o.desc}</span>
            </button>
          `).join('')}
        </div>
      `;

      questionEl.querySelectorAll('[data-value]').forEach((btn) => {
        btn.addEventListener('click', () => {
          answers[s.key] = btn.dataset.value;
          renderState();
          if (step < steps.length - 1) {
            step++;
            renderQuestion();
            updateProgress();
            animate();
          } else {
            renderResults();
            animate();
          }
        });
      });

      updateProgress();
    };

    const rank = () => {
      return products.map((p) => {
        let score = 0;
        steps.forEach((s) => {
          const ans = norm(answers[s.key]);
          const tags = (p[s.key] || []).map(norm);
          if (tags.includes(ans)) score += 25;
        });
        return { ...p, score };
      }).sort((a, b) => b.score - a.score).slice(0, 3);
    };

    const renderResults = () => {
      const matches = rank();
      questionEl.innerHTML = `
        <h3 class="duftfinder__question-title">Deine Empfehlungen</h3>
        <p class="duftfinder__question-subtitle">Basierend auf deinen Antworten</p>
        <div class="duftfinder__results">
          ${matches.map((m, i) => `
            <a href="${m.url || '/collections/all'}" class="duftfinder__result" data-top="${i === 0}">
              ${m.image ? `<img class="duftfinder__result-image" src="${m.image}" alt="${m.title}" loading="lazy">` : '<div class="duftfinder__result-image"></div>'}
              <div class="duftfinder__result-content">
                <span class="duftfinder__result-match">${m.score}% Match</span>
                <h4 class="duftfinder__result-title">${m.title}</h4>
                ${m.subtitle ? `<span class="duftfinder__result-subtitle">${m.subtitle}</span>` : ''}
                ${m.price ? `<span class="duftfinder__result-price">${m.price}</span>` : ''}
              </div>
            </a>
          `).join('')}
        </div>
      `;

      progressBar.style.width = '100%';
      progressText.textContent = '✓';
      backBtn.hidden = true;
      resetBtn.hidden = false;
    };

    const reset = () => {
      Object.keys(answers).forEach((k) => delete answers[k]);
      step = 0;
      backBtn.hidden = false;
      backBtn.disabled = true;
      resetBtn.hidden = true;
      renderState();
      renderQuestion();
      animate();
    };

    backBtn.addEventListener('click', () => {
      if (step === 0) return;
      delete answers[steps[step].key];
      step--;
      renderState();
      renderQuestion();
      animate();
    });

    resetBtn.addEventListener('click', reset);

    // Init
    renderQuestion();
  })();
</script>

{% schema %}
{
  "name": "Duftfinder",
  "tag": "section",
  "class": "section-duftfinder",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Duftberater"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Finde deinen perfekten Duft"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterzeile",
      "default": "Beantworte vier kurze Fragen und entdecke Düfte, die zu dir passen."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produkt",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel (überschreibt Produktname)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Untertitel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Kurzbeschreibung"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (überschreibt Produkt-URL)"
        },
        {
          "type": "text",
          "id": "mood_tags",
          "label": "Mood Tags",
          "info": "Kommagetrennt: ruhig, warm, klar, sinnlich"
        },
        {
          "type": "text",
          "id": "atmosphere_tags",
          "label": "Atmosphäre Tags",
          "info": "Kommagetrennt: natur, spa, zuhause, ritual"
        },
        {
          "type": "text",
          "id": "character_tags",
          "label": "Charakter Tags",
          "info": "Kommagetrennt: blumig, holzig, suess, harzig"
        },
        {
          "type": "text",
          "id": "intensity_tags",
          "label": "Intensität Tags",
          "info": "Kommagetrennt: sanft, ausgewogen, tief, frisch"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duftfinder",
      "blocks": []
    }
  ]
}
{% endschema %}
