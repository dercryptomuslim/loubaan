{% doc %}
  Renders trust badges for LOUBAAN store to boost conversion.
  Displays shipping, payment security, quality, and return policy badges.

  @example
  {% render 'loubaan-trust-badges' %}
{% enddoc %}

<div class="loubaan-trust-badges" role="complementary" aria-label="Vertrauensmerkmale">
  <div class="trust-badges__grid">
    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 18H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.19M15 6h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-3.19"/><line x1="23" y1="13" x2="23" y2="11"/><polyline points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="trust-badge__text">
        <span class="trust-badge__title">Premium Qualit&auml;t</span>
        <span class="trust-badge__subtitle">100% nat&uuml;rliche Inhaltsstoffe</span>
      </div>
    </div>
    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </div>
      <div class="trust-badge__text">
        <span class="trust-badge__title">Gratis Versand</span>
        <span class="trust-badge__subtitle">Kostenlos in ganz Deutschland</span>
      </div>
    </div>
    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <div class="trust-badge__text">
        <span class="trust-badge__title">Sicher Bezahlen</span>
        <span class="trust-badge__subtitle">SSL-verschl&uuml;sselte Zahlung</span>
      </div>
    </div>
    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      </div>
      <div class="trust-badge__text">
        <span class="trust-badge__title">Zufriedenheit</span>
        <span class="trust-badge__subtitle">&Uuml;ber 1.000+ zufriedene Kunden</span>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .loubaan-trust-badges {
    margin: 2rem 0;
    padding: 1.6rem 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.4rem;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .trust-badge__icon {
    flex-shrink: 0;
    color: rgb(var(--color-foreground));
    opacity: 0.7;
  }

  .trust-badge__text {
    display: flex;
    flex-direction: column;
  }

  .trust-badge__title {
    font-size: 1.3rem;
    font-weight: var(--font-body-weight-bold);
    line-height: 1.3;
    color: rgb(var(--color-foreground));
  }

  .trust-badge__subtitle {
    font-size: 1.1rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.6);
  }

  @media screen and (max-width: 749px) {
    .trust-badges__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.2rem;
    }

    .trust-badge__icon svg {
      width: 22px;
      height: 22px;
    }

    .trust-badge__title {
      font-size: 1.2rem;
    }

    .trust-badge__subtitle {
      font-size: 1rem;
    }
  }

  @media screen and (max-width: 480px) {
    .trust-badges__grid {
      grid-template-columns: 1fr;
    }

    .trust-badge {
      gap: 0.8rem;
    }
  }
{% endstylesheet %}
