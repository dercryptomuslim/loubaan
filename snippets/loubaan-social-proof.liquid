{% doc %}
  Renders a social proof / reviews summary bar for product pages.
  Falls back to store-wide stats when no product reviews exist.

  @param {product} product - The product object

  @example
  {% render 'loubaan-social-proof', product: product %}
{% enddoc %}

{%- liquid
  assign has_reviews = false
  if product.metafields.reviews.rating.value != blank
    assign has_reviews = true
    assign rating_value = product.metafields.reviews.rating.value.rating
    assign rating_max = product.metafields.reviews.rating.value.scale_max
    assign review_count = product.metafields.reviews.rating_count
  endif
-%}

<div class="loubaan-social-proof">
  <div class="social-proof__inner">
    {%- if has_reviews -%}
      <div class="social-proof__rating">
        <div class="social-proof__stars" aria-label="{{ rating_value }} von {{ rating_max }} Sternen">
          {%- for i in (1..5) -%}
            <svg class="social-proof__star{% if i <= rating_value %} social-proof__star--filled{% endif %}" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="{% if i <= rating_value %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {%- endfor -%}
        </div>
        <span class="social-proof__count">{{ rating_value }}/{{ rating_max }} ({{ review_count }} Bewertungen)</span>
      </div>
    {%- else -%}
      <div class="social-proof__stats">
        <div class="social-proof__stat">
          <span class="social-proof__stat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <span class="social-proof__stat-text">1.000+ Kunden vertrauen LOUBAAN</span>
        </div>
        <div class="social-proof__stat">
          <span class="social-proof__stat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </span>
          <span class="social-proof__stat-text">4.8/5 Kundenzufriedenheit</span>
        </div>
        <div class="social-proof__stat">
          <span class="social-proof__stat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </span>
          <span class="social-proof__stat-text">100% nat&uuml;rlich &amp; handgefertigt</span>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .loubaan-social-proof {
    margin: 1.2rem 0;
    padding: 1rem 1.4rem;
    background: rgba(var(--color-foreground), 0.02);
    border-radius: 0.6rem;
    border: 1px solid rgba(var(--color-foreground), 0.05);
  }

  .social-proof__inner {
    display: flex;
    align-items: center;
  }

  .social-proof__rating {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .social-proof__stars {
    display: flex;
    gap: 0.2rem;
  }

  .social-proof__star {
    color: #d4a853;
  }

  .social-proof__star--filled {
    color: #d4a853;
  }

  .social-proof__count {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.65);
  }

  .social-proof__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    width: 100%;
  }

  .social-proof__stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-proof__stat-icon {
    flex-shrink: 0;
    color: #d4a853;
  }

  .social-proof__stat-text {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.7);
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .social-proof__stats {
      flex-direction: column;
      gap: 0.8rem;
    }

    .social-proof__stat-text {
      white-space: normal;
    }
  }
{% endstylesheet %}
