{% doc %}
  Renders a sticky add-to-cart bar for mobile devices.
  Shows product title, price, and add-to-cart button when scrolled past main CTA.

  @param {product} product - The product object
  @param {string} section_id - The section ID for form targeting

  @example
  {% render 'loubaan-sticky-atc', product: product, section_id: section.id %}
{% enddoc %}

{%- if product.available -%}
  <div class="loubaan-sticky-atc" id="loubaan-sticky-atc" aria-hidden="true">
    <div class="sticky-atc__inner page-width">
      <div class="sticky-atc__info">
        <span class="sticky-atc__title">{{ product.title | truncate: 30 }}</span>
        <span class="sticky-atc__price">
          {%- if product.price_varies -%}
            {{ 'products.product.price.from_price_html' | t: price: product.price | money_with_currency }}
          {%- else -%}
            {{ product.price | money_with_currency }}
          {%- endif -%}
        </span>
      </div>
      <button
        type="button"
        class="sticky-atc__button button button--full-width"
        aria-label="{{ 'products.product.add_to_cart' | t }}"
        onclick="document.querySelector('product-form[data-section=&quot;{{ section_id }}&quot;] [type=submit]').click(); return false;"
      >
        <span>{{ 'products.product.add_to_cart' | t }}</span>
      </button>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .loubaan-sticky-atc {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgb(var(--color-background));
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    box-shadow: 0 -4px 20px rgba(var(--color-shadow), 0.08);
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    padding: 1rem 0;
  }

  .loubaan-sticky-atc.is-visible {
    transform: translateY(0);
  }

  .sticky-atc__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
  }

  .sticky-atc__info {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }

  .sticky-atc__title {
    font-size: 1.3rem;
    font-weight: var(--font-body-weight-bold);
    color: rgb(var(--color-foreground));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-atc__price {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .sticky-atc__button {
    flex-shrink: 0;
    min-width: 14rem;
    padding: 1rem 2rem;
    font-size: 1.3rem;
  }

  @media screen and (min-width: 990px) {
    .loubaan-sticky-atc {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .loubaan-sticky-atc {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    const stickyBar = document.getElementById('loubaan-sticky-atc');
    if (!stickyBar) return;

    const productForm = document.querySelector('product-form');
    if (!productForm) return;

    const submitBtn = productForm.querySelector('[type="submit"]');
    if (!submitBtn) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            stickyBar.classList.remove('is-visible');
            stickyBar.setAttribute('aria-hidden', 'true');
          } else {
            stickyBar.classList.add('is-visible');
            stickyBar.setAttribute('aria-hidden', 'false');
          }
        });
      },
      { threshold: 0, rootMargin: '0px 0px 100px 0px' }
    );

    observer.observe(submitBtn);
  })();
{% endjavascript %}
