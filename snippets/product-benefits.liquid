{% comment %}
  LOUBAAN Benefit Checkmarks — Above Product Description
  Pulls from product metafields or shows defaults based on product type
{% endcomment %}

{%- liquid
  assign benefit_1 = product.metafields.loubaan.benefit_1
  assign benefit_2 = product.metafields.loubaan.benefit_2
  assign benefit_3 = product.metafields.loubaan.benefit_3
  
  # Default benefits based on product type/tags
  unless benefit_1
    if product.type == 'Weihrauch'
      assign benefit_1 = 'Premium Weihrauch aus kontrolliertem Anbau'
      assign benefit_2 = 'Ideal für Meditation, Entspannung & Rituale'
      assign benefit_3 = 'Traditionelle Qualität, handverlesen'
    elsif product.tags contains 'blends'
      assign benefit_1 = 'Handgefertigte Duftkomposition'
      assign benefit_2 = '100% naturreine ätherische Öle'
      assign benefit_3 = 'Für Diffuser, Aromatherapie & Körperpflege'
    elsif product.tags contains 'ätherisches öl' or product.tags contains 'öle'
      assign benefit_1 = '100% naturreines ätherisches Öl'
      assign benefit_2 = 'Ohne synthetische Zusätze'
      assign benefit_3 = 'Für Aromatherapie & Wellness'
    else
      assign benefit_1 = '100% naturrein & hochwertig'
      assign benefit_2 = 'Handverlesen & qualitätsgeprüft'
      assign benefit_3 = 'Für dein tägliches Wohlbefinden'
    endif
  endunless
-%}

<div class="loubaan-benefits">
  <ul class="loubaan-benefits__list">
    <li class="loubaan-benefits__item">
      <svg class="loubaan-benefits__check" width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>{{ benefit_1 }}</span>
    </li>
    <li class="loubaan-benefits__item">
      <svg class="loubaan-benefits__check" width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>{{ benefit_2 }}</span>
    </li>
    <li class="loubaan-benefits__item">
      <svg class="loubaan-benefits__check" width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>{{ benefit_3 }}</span>
    </li>
  </ul>
</div>

<style>
  .loubaan-benefits {
    margin: 1rem 0 1.5rem;
  }

  .loubaan-benefits__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .loubaan-benefits__item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.85);
  }

  .loubaan-benefits__check {
    flex-shrink: 0;
    color: #2E7D32;
    margin-top: 0.125rem;
  }
</style>
